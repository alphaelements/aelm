# aelm-version: 0.4.2
// csv-plot — CSV-source plot traces with LTTB decimation.
// Loads a captured waveform from `data/scope-capture.csv`.

module CsvPlot {
    plots {
        SCOPE: plot {
            size: (60, 25)
            source: "data/scope-capture.csv"
            x: { col: "time", range: 0..0.005, label: "t [s]", grid: true }
            y: { col: "voltage", range: -1.2..1.2, label: "V" }
            decimation: { max_points: 2000 }
            place: (3, -13)
        }
    }
}
